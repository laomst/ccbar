<idea-plugin>
    <id>com.github.ccbar</id>
    <name>CCBar</name>
    <vendor url="https://github.com/laomst/ccbar" email="laomst@163.com">laomst</vendor>
    <description><![CDATA[
        <h2>CCBar - Quick Command Launcher for IDEA Toolbar</h2>
        <p>CCBar 是一个 IntelliJ IDEA 插件，在工具栏中添加可配置的快捷按钮，用于在终端标签页中快速启动命令。主要使用场景是以不同参数组合启动 AI 编程助手（如 Claude Code），也适用于任何需要频繁执行的命令行工具。</p>

        <h3>核心特性</h3>
        <ul>
            <li><strong>三层配置结构</strong>：CommandBar → Command → QuickParam，灵活组织命令</li>
            <li><strong>两种工作模式</strong>：直接命令模式一键执行，命令列表模式快速切换</li>
            <li><strong>环境变量支持</strong>：公共 + 命令级两层环境变量，自动适配不同 Shell</li>
            <li><strong>终端模式可选</strong>：支持工具窗口模式和编辑器模式</li>
            <li><strong>自定义图标</strong>：支持内置图标、本地文件、网络图片</li>
            <li><strong>配置导入导出</strong>：JSON 格式便于跨环境迁移和团队共享</li>
        </ul>

        <h3>快速开始</h3>
        <ol>
            <li>安装后工具栏自动出现 <code>Claude Code</code> 按钮</li>
            <li>点击按钮选择命令或快捷参数</li>
            <li>在命令预览对话框中确认并执行</li>
            <li>进入 <strong>Settings → Tools → CCBar</strong> 自定义配置</li>
        </ol>

        <h3>使用场景</h3>
        <ul>
            <li>AI 编程助手快速启动（Claude Code、Codex 等）</li>
            <li>项目构建脚本（npm、docker compose 等）</li>
            <li>常用命令一键执行</li>
            <li>多项目差异化配置</li>
        </ul>

        <p><a href="https://github.com/laomst/ccbar">GitHub 仓库</a> | <a href="https://github.com/laomst/ccbar/blob/main/README.md">使用文档</a></p>
    ]]></description>
    <change-notes><![CDATA[
        <h2>1.0.0</h2>
        <ul>
            <li>初始版本发布</li>
            <li>支持 CommandBar → Command → QuickParam 三层配置</li>
            <li>支持直接命令模式和命令列表模式</li>
            <li>支持环境变量配置（公共 + 命令级）</li>
            <li>支持终端工具窗口和编辑器两种模式</li>
            <li>支持自定义图标（内置/本地/网络）</li>
            <li>支持系统配置和项目配置</li>
            <li>支持配置导入导出</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- 配置持久化 -->
        <applicationService
            serviceImplementation="site.laomst.ccbar.settings.CCBarSettings"/>
        <projectService
            serviceImplementation="site.laomst.ccbar.settings.CCBarProjectSettings"/>

        <!-- 设置页面 -->
        <projectConfigurable
            parentId="tools"
            instance="site.laomst.ccbar.settings.CCBarSettingsConfigurable"
            id="site.laomst.ccbar.settings"
            displayName="CCBar"/>

        <!-- 通知组 -->
        <notificationGroup id="CCBar" displayType="BALLOON"/>

        <!-- 终端编辑器提供者 -->
        <fileEditorProvider
            implementation="site.laomst.ccbar.terminal.editor.TerminalEditorProvider"/>

        <!-- 终端文件图标提供者 -->
        <fileIconProvider
            implementation="site.laomst.ccbar.terminal.editor.TerminalFileIconProvider"/>
    </extensions>

    <actions>
        <!-- 动态注册：工具栏按钮通过 DynamicActionGroup 在运行时根据配置创建 -->
        <group id="CCBar.ToolbarGroup"
               class="site.laomst.ccbar.actions.CCBarToolbarActionGroup"
               text="CCBar"
               popup="false"
               description="CCBar Quick Command Launcher"
               icon="AllIcons.Actions.Execute">
            <!-- New UI 工具栏右侧（2022.3+ 默认界面） -->
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <!-- Classic UI 工具栏（旧界面兼容） -->
            <add-to-group group-id="MainToolBar" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
